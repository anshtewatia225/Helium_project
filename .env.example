# --- Local dev (Vite proxy) ---
# Get a free key at https://console.groq.com/keys
# Used only by the Vite dev-server proxy; never shipped to the browser.
VITE_GROQ_API_KEY=

# --- Production (Vercel build) ---
# URL of the deployed Render proxy, e.g. https://shopper-intent-proxy.onrender.com/api/groq
# Leave blank locally so it falls back to the Vite proxy at /api/groq.
VITE_API_BASE_URL=
